# ParkSphere Enterprise — no-Docker laptop mode.
# Used by setup-nodocker.bat. SQLite file only. No Postgres / Redis / Docker.
#
# IMPORTANT: rotate the secrets below before deploying anywhere real.

# --------------------------------------------------------------------------
# API (apps/api/.env)
# --------------------------------------------------------------------------
# SQLite file. Prisma resolves relative paths against the schema directory,
# so this ends up at apps/api/prisma/parksphere.db.
DATABASE_URL="file:./parksphere.db"

JWT_SECRET="dev-only-jwt-secret-change-me-before-shipping-anywhere-real"

API_PORT=4000
API_CORS_ORIGIN="http://localhost:3000"

# --------------------------------------------------------------------------
# WhatsApp (Twilio) — OPTIONAL
# --------------------------------------------------------------------------
# Set all three to enable live WhatsApp sending. Leave blank for DRY-RUN
# mode (the system still schedules + records reminders, just logs the body
# instead of actually sending — perfect for development).
#
# Twilio sandbox flow:
#   1. Sign up at https://www.twilio.com — Console → Messaging → Try it out → WhatsApp
#   2. Get your Account SID + Auth Token from the console.
#   3. The sandbox From number is shown there, usually +14155238886
#   4. Recipients must opt in by sending the "join <code>" message to the sandbox first.
# Production:
#   - Apply for a WhatsApp Business sender number (~1-7 day approval).
#   - Register your message templates in Twilio Content Builder / Meta Business Manager.
#TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#TWILIO_WHATSAPP_FROM=+14155238886

# --------------------------------------------------------------------------
# Web (apps/web/.env.local)
# --------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"
