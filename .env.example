# ParkSphere Enterprise — Docker mode (Postgres).
# Used by setup.bat. Spins up Postgres via docker-compose.yml.
#
# Setup:
#   Copy this file to apps/api/.env       (API + database settings)
#   Copy this file to apps/web/.env.local (NEXT_PUBLIC_* only)
#
# IMPORTANT: rotate every secret below before deploying anywhere real.
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

# --------------------------------------------------------------------------
# API (apps/api/.env)
# --------------------------------------------------------------------------
DATABASE_URL="postgresql://parksphere:parksphere_dev@localhost:5432/parksphere?schema=public"

JWT_SECRET="dev-only-jwt-secret-change-me-before-shipping-anywhere-real"

API_PORT=4000
API_CORS_ORIGIN="http://localhost:3000"

# --------------------------------------------------------------------------
# Web (apps/web/.env.local)
# --------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"
