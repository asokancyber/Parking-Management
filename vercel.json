{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && npm install && cd apps/web && npm run build",
  "installCommand": "cd ../.. && npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "build": {
    "env": {
      "NEXT_PUBLIC_DEMO_MODE": "true",
      "NEXT_PUBLIC_API_BASE_URL": "",
      "NEXT_PUBLIC_WS_URL": ""
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
