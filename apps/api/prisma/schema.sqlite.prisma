// ParkSphere Enterprise — SQLite variant (no-Docker laptop mode).
// Enums become String columns; values are validated by TypeScript via
// src/common/enums.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── MODELS ───────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String // UserRole — see src/common/enums.ts
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  driver Driver?

  @@index([role])
}

model Driver {
  id              String   @id @default(cuid())
  publicId        String   @unique
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone           String   @unique
  fullName        String
  company         String?
  preferredChannel String  @default("WHATSAPP") // ReminderChannel
  whatsappOptOut  Boolean  @default(false)
  // Driver portal lifecycle
  forceChangePassword Boolean @default(false) // set true on admin-created accounts
  lockedAt        DateTime?
  lockedReason    String?
  lastLoginAt     DateTime?
  passwordChangedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicles        Vehicle[]
  subscriptions   Subscription[]
  cards           Card[]
  cardAssignments CardAssignment[]
  taps            CardTapEvent[]
  reminders       Reminder[]
}

model Vehicle {
  id         String   @id @default(cuid())
  plate      String   @unique
  type       String
  driverId   String
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  taps CardTapEvent[]
}

model Subscription {
  id              String   @id @default(cuid())
  driverId        String
  driver          Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  planName        String
  priceCents      Int
  currency        String   @default("MYR")
  status          String   @default("PENDING_PAYMENT") // SubscriptionStatus
  startsAt        DateTime
  expiresAt       DateTime
  autoRenew       Boolean  @default(false)
  gracePeriodDays Int      @default(3)
  // Snapshot of last successful renewal — for receipt + audit purposes.
  lastRenewedAt   DateTime?
  lastRenewedFor  Int?     // days added on last renewal
  lastPaymentRef  String?  // operator-entered ref / gateway txn id
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reminders       Reminder[]

  @@index([driverId])
  @@index([status, expiresAt])
}

model Gate {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  direction   String // GateDirection
  status      String   @default("ONLINE") // GateStatus
  zone        String?
  capacity    Int      @default(0)
  occupancy   Int      @default(0)
  accessToken String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taps CardTapEvent[]
}

model Card {
  id         String    @id @default(cuid())
  uid        String    @unique
  label      String?
  status     String    @default("IN_STOCK") // CardStatus
  driverId   String?
  driver     Driver?   @relation(fields: [driverId], references: [id], onDelete: SetNull)
  issuedAt   DateTime?
  expiresAt  DateTime?
  notes      String?
  replacesId String?   @unique
  replaces   Card?     @relation("CardReplacement", fields: [replacesId], references: [id])
  replacedBy Card?     @relation("CardReplacement")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  taps        CardTapEvent[]
  assignments CardAssignment[]

  @@index([status])
  @@index([driverId])
}

model CardAssignment {
  id        String   @id @default(cuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  fromAt    DateTime @default(now())
  toAt      DateTime?
  reason    String
  actorId   String?

  @@index([cardId])
  @@index([driverId])
}

model CardTapEvent {
  id        String   @id @default(cuid())
  gateId    String
  gate      Gate     @relation(fields: [gateId], references: [id])
  cardUid   String
  cardId    String?
  card      Card?    @relation(fields: [cardId], references: [id])
  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id])
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  result    String // TapResult
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([gateId, createdAt])
  @@index([cardId, createdAt])
  @@index([driverId, createdAt])
  @@index([result])
}

model AuditLog {
  id         String   @id @default(cuid())
  category   String // AuditCategory
  actorId    String?
  actorRole  String? // UserRole
  action     String
  targetType String?
  targetId   String?
  metadata   String? // JSON-encoded
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([category, createdAt])
  @@index([actorId, createdAt])
}

model AppSetting {
  key       String   @id
  value     String // JSON-encoded
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// A scheduled or sent renewal reminder. Each subscription generates a fan of
// these on creation/renewal (T-14, T-7, T-3, T-1, T-0, grace, lapsed). The
// dispatcher cron picks SCHEDULED rows whose scheduledFor is past and tries
// the channel adapter. Failed sends retry with backoff; cancelled rows fire
// when the driver renews before the reminder's time.
model Reminder {
  id              String   @id @default(cuid())
  driverId        String
  driver          Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  kind            String // ReminderKind
  channel         String // ReminderChannel
  status          String   @default("SCHEDULED") // ReminderStatus
  scheduledFor    DateTime
  sentAt          DateTime?
  deliveredAt     DateTime?
  failedAt        DateTime?
  cancelledAt     DateTime?
  attempts        Int      @default(0)
  failReason      String?
  externalId      String?  // provider message id
  renderedBody    String?  // snapshot of rendered template (for audit)
  recipientPhone  String?  // snapshot of phone at send time
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, scheduledFor])
  @@index([driverId, createdAt])
  @@index([subscriptionId])
}

// Subscription plan presets. The Subscription model still stores planName +
// priceCents as a snapshot, so historical records survive plan edits.
model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  priceCents   Int
  durationDays Int
  description  String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
}
