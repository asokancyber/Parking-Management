{
  "name": "@parksphere/api",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "prisma:push:sqlite": "prisma db push --schema=./prisma/schema.sqlite.prisma --accept-data-loss --skip-generate && prisma generate --schema=./prisma/schema.sqlite.prisma",
    "prisma:push:postgres": "prisma db push --schema=./prisma/schema.postgres.prisma --accept-data-loss --skip-generate && prisma generate --schema=./prisma/schema.postgres.prisma",
    "prisma:migrate:postgres": "prisma migrate dev --schema=./prisma/schema.postgres.prisma --name init",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/platform-socket.io": "^10.4.4",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/websockets": "^10.4.4",
    "@prisma/client": "^5.20.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^3.3.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
