# ParkSphere Enterprise — no-Docker laptop mode.
#
# Used by setup-nodocker.bat. SQLite file + in-memory QR token store.
# No Postgres, no Redis, no Docker required.
#
# IMPORTANT: rotate the secrets below before deploying anywhere real.

# --------------------------------------------------------------------------
# API (apps/api/.env)
# --------------------------------------------------------------------------
# SQLite file. Prisma resolves relative paths against the schema file's
# directory, so this ends up at apps/api/prisma/parksphere.db.
DATABASE_URL="file:./parksphere.db"

# Tells the API to use the in-process token store instead of Redis.
TOKEN_STORE=memory

JWT_SECRET="dev-only-jwt-secret-change-me-before-shipping-anywhere-real"
QR_SIGNING_SECRET="dev-only-qr-signing-secret-change-me-before-shipping-anywhere-real"

API_PORT=4000
API_CORS_ORIGIN="http://localhost:3000"

QR_DEFAULT_TIMEOUT_SECONDS=60

# --------------------------------------------------------------------------
# Web (apps/web/.env.local)
# --------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"
